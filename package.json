{
  "name": "ghent",
  "version": "0.2.0",
  "license": "MIT",
  "description": "Ghent (GHE Notifications) — Windows toast notifier for GitHub Enterprise PR activity.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-start.ps1",
    "dev:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-stop.ps1",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "register": "tsx src/register-webhook.ts",
    "unregister": "tsx src/register-webhook.ts --remove",
    "list-hooks": "tsx src/register-webhook.ts --list",
    "discover-repos": "tsx src/discover-repos.ts",
    "test-toast": "tsx src/notifier.ts --test",
    "bundle": "node scripts/build-bundle.mjs",
    "msi": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-msi.ps1",
    "deploy": "npm run bundle && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-local.ps1"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-notifier": "^10.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/node-notifier": "^8.0.5",
    "esbuild": "^0.21.5",
    "sharp": "^0.34.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
