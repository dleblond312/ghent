# --- Required ---

# Your GHE handle (your-company.ghe.com username). Used to filter events to
# only PRs you authored, and to skip notifying on your own comments.
GHE_USERNAME=your-username

# Personal access token (classic) on your GHE instance with scopes:
#   - repo (to read PRs and register hooks on private repos)
#   - admin:repo_hook (to create/delete repo webhooks)
#   - admin:org_hook (only if REGISTER_SCOPE=org)
GHE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx

# GHE base API URL. For your-company.ghe.com:
GHE_API_BASE=https://your-company.ghe.com/api/v3

# Public URL where GHE will POST webhook events. Must be reachable from
# your GHE instance and end in /webhook. Use your Microsoft DevTunnel URL.
# Example: https://YOUR-TUNNEL.devtunnels.ms/webhook
PUBLIC_WEBHOOK_URL=https://YOUR-TUNNEL.devtunnels.ms/webhook

# Shared secret used to sign payloads (HMAC-SHA256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace-with-32-byte-hex-secret

# --- Optional ---

# Local port the express server listens on. MUST match the port your
# devtunnel is hosting (e.g. `devtunnel host -p 51847`).
PORT=51847

# webhook | poll
# poll    = recommended default. No tunnel needed, ~60s latency, no port
#           collisions, naturally survives sleep/wake, picks up ALL open PRs
#           you authored (not just recent repos).
# webhook = real-time, requires a publicly reachable URL (DevTunnel) and
#           a free local PORT. Useful if you need <5s latency.
MODE=poll

# Polling cadence (only used if MODE=poll).
POLL_INTERVAL_SEC=60

# Comma-separated list of repos (owner/name) to register the webhook on.
# Use `npm run discover-repos` to auto-populate this from PRs you authored
# in the last 90 days.
REGISTER_REPOS=org/repo-one,org/repo-two

# Scope for registration. Currently only "repo" is implemented (per-repo
# hooks). GHE doesn't expose a user-level webhook API for regular users.
# Set to "org" if you have admin:org_hook on a specific org and want a
# single hook covering everything in that org.
REGISTER_SCOPE=repo

# If REGISTER_SCOPE=org, the org name (e.g. "your-org").
REGISTER_ORG=your-org

# How many days back to look when running `npm run discover-repos`.
DISCOVER_DAYS=90
